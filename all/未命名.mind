{"root":{"data":{"id":"dh5ys5z9q8w0","created":1773842768163,"text":"中心主题"},"children":[{"data":{"id":"dh5yscxkdtk0","created":1773842783298,"text":"1. 实验模型构建与表型验证","layout":null,"layout_right_offset":{"x":-75,"y":-27}},"children":[{"data":{"id":"dh5z2cwh9ds0","created":1773843566874,"text":"耐药株诱导与鉴定：采用 HCT116 细胞进行奥沙利铂（OXA）阶梯浓度递增诱导，构建 HCT116-OXA 耐药株；利用 MTT 法计算 IC50 值评价耐药指数，通过克隆形成实验评估长期药物耐受性。","layout_right_offset":{"x":-18,"y":-64}},"children":[]},{"data":{"id":"dh5z2gs30bk0","created":1773843575315,"text":"分支主题"},"children":[]}]},{"data":{"id":"dh5z2c57vcg0","created":1773843565225,"text":"分支主题"},"children":[]},{"data":{"id":"dh5ytswczxc0","created":1773842896418,"text":"分支主题"},"children":[]},{"data":{"id":"dh5yt5zjat40","created":1773842846544,"text":"分支主题","layout_right_offset":{"x":275,"y":-114}},"children":[]},{"data":{"id":"dh5ysehnreg0","created":1773842786690,"text":"分支主题分支主题","layout":null},"children":[]}]},"template":"right","theme":"fresh-blue","version":"1.4.43"}