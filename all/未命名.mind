{"root":{"data":{"id":"dh5ys5z9q8w0","created":1773842768163,"text":"中心主题"},"children":[{"data":{"id":"dh5z3yvo0540","created":1773843693078,"text":"分子机制研究","priority":1},"children":[{"data":{"id":"dh5z427xo5s0","created":1773843700350,"text":"1. 实验模型构建与表型验证"},"children":[{"data":{"id":"dh5z46uxicg0","created":1773843710448,"text":"耐药株诱导与鉴定：采用 HCT116 细胞进行奥沙利铂（OXA）阶梯浓度递增诱导，构建 HCT116-OXA 耐药株；利用 MTT 法计算 IC50 值评价耐药指数，通过克隆形成实验评估长期药物耐受性。"},"children":[]}]}]}]},"template":"right","theme":"fresh-blue","version":"1.4.43"}